{
  "manifest_version": 3,
  "name": "Chess Pressure Heatmap",
  "version": "1.0.0",
  "description": "Overlays a pressure heatmap on chess.com boards, showing which squares are controlled by each side.",
  "permissions": [],
  "host_permissions": [
    "https://www.chess.com/*",
    "https://chess.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*",
        "https://chess.com/*"
      ],
      "js": [
        "chess-engine.js",
        "overlay.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Chess Pressure Heatmap"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.chess.com/*", "https://chess.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}